generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String                     @db.VarChar(160)
  slug                      String                     @unique @db.VarChar(80)
  status                    OrganizationStatus         @default(ACTIVE)
  primaryDomain             String?                    @map("primary_domain") @db.VarChar(255)
  entraTenantId             String?                    @unique @map("entra_tenant_id") @db.VarChar(128)
  settings                  Json                       @default("{}")
  metadata                  Json                       @default("{}")
  createdAt                 DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  version                   Int                        @default(1)
  activityFeed              ActivityFeed[]
  analyticsDailySnapshots   AnalyticsDailySnapshot[]
  analyticsQuarterSnapshots AnalyticsQuarterSnapshot[]
  auditLogs                 AuditLog[]
  checkIns                  CheckIn[]
  escalationLogs            EscalationLog[]
  goalApprovals             GoalApproval[]
  goalComments              GoalComment[]
  goalPlans                 GoalPlan[]
  goals                     Goal[]
  governanceWindows         GovernanceWindow[]
  kpiAssignments            KpiAssignment[]
  kpiDefinitions            KpiDefinition[]
  kpiSyncLogs               KpiSyncLog[]
  notifications             Notification[]
  performanceCycles         PerformanceCycle[]
  teamMemberships           TeamMembership[]
  teams                     Team[]
  users                     User[]

  @@index([status])
  @@map("organizations")
}

model User {
  id                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId            String                     @map("organization_id") @db.Uuid
  managerId                 String?                    @map("manager_id") @db.Uuid
  teamId                    String?                    @map("team_id") @db.Uuid
  email                     String                     @db.VarChar(320)
  emailNormalized           String                     @map("email_normalized") @db.VarChar(320)
  emailVerified             DateTime?                  @map("email_verified") @db.Timestamptz(6)
  name                      String?                    @db.VarChar(160)
  displayName               String                     @map("display_name") @db.VarChar(160)
  avatarUrl                 String?                    @map("avatar_url")
  employeeCode              String?                    @map("employee_code") @db.VarChar(64)
  entraObjectId             String?                    @map("entra_object_id") @db.VarChar(128)
  role                      UserRole                   @default(EMPLOYEE)
  status                    UserStatus                 @default(INVITED)
  designation               String?                    @db.VarChar(160)
  department                String?                    @db.VarChar(160)
  isActive                  Boolean                    @default(true) @map("is_active")
  timezone                  String                     @default("UTC") @db.VarChar(64)
  locale                    String                     @default("en-US") @db.VarChar(32)
  lastLoginAt               DateTime?                  @map("last_login_at") @db.Timestamptz(6)
  deletedAt                 DateTime?                  @map("deleted_at") @db.Timestamptz(6)
  metadata                  Json                       @default("{}")
  createdAt                 DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  version                   Int                        @default(1)
  accounts                  Account[]
  activities                ActivityFeed[]
  analyticsQuarterSnapshots AnalyticsQuarterSnapshot[]
  auditLogs                 AuditLog[]
  authenticators            Authenticator[]
  checkInsReviewed          CheckIn[]                  @relation("CheckInReviewer")
  checkInsSubmitted         CheckIn[]                  @relation("CheckInSubmitter")
  escalationAssignee        EscalationLog[]            @relation("EscalationAssignee")
  escalationSubjects        EscalationLog[]            @relation("EscalationSubject")
  approvalApprover          GoalApproval[]             @relation("GoalApprovalApprover")
  approvalDecider           GoalApproval[]             @relation("GoalApprovalDecider")
  approvalRequester         GoalApproval[]             @relation("GoalApprovalRequester")
  approvalSubject           GoalApproval[]             @relation("GoalApprovalSubject")
  comments                  GoalComment[]
  goalPlansApproved         GoalPlan[]                 @relation("GoalPlanApprover")
  goalPlans                 GoalPlan[]                 @relation("GoalPlanOwner")
  goalPlansSubmitted        GoalPlan[]                 @relation("GoalPlanSubmitter")
  goalsApproved             Goal[]                     @relation("GoalApprover")
  goalsCreated              Goal[]                     @relation("GoalCreator")
  goalsOwned                Goal[]                     @relation("GoalOwner")
  goalsUpdated              Goal[]                     @relation("GoalUpdater")
  kpiAssignmentsMade        KpiAssignment[]            @relation("KpiAssignmentCreator")
  assignedKpis              KpiAssignment[]            @relation("KpiAssignmentAssignee")
  kpisOwned                 KpiDefinition[]            @relation("KpiDefinitionOwner")
  notifications             Notification[]
  sessions                  Session[]
  teamMemberships           TeamMembership[]
  managedTeams              Team[]                     @relation("TeamManager")
  manager                   User?                      @relation("UserManager", fields: [managerId], references: [id])
  directReports             User[]                     @relation("UserManager")
  organization              Organization               @relation(fields: [organizationId], references: [id])
  team                      Team?                      @relation("UserTeam", fields: [teamId], references: [id])

  @@unique([organizationId, emailNormalized], map: "users_org_email_normalized_key")
  @@unique([organizationId, employeeCode], map: "users_org_employee_code_key")
  @@unique([organizationId, entraObjectId], map: "users_org_entra_object_id_key")
  @@index([organizationId, managerId, isActive], map: "users_org_manager_active_idx")
  @@index([organizationId, teamId, isActive], map: "users_org_team_active_idx")
  @@index([organizationId, role, status], map: "users_org_role_status_idx")
  @@index([organizationId, deletedAt], map: "users_org_deleted_at_idx")
  @@map("users")
}

model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String  @db.VarChar(64)
  provider          String  @db.VarChar(64)
  providerAccountId String  @map("provider_account_id") @db.VarChar(191)
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type") @db.VarChar(64)
  scope             String?
  idToken           String? @map("id_token")
  sessionState      String? @map("session_state") @db.VarChar(255)
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique @map("session_token") @db.VarChar(255)
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
  @@map("sessions")
}

model VerificationToken {
  identifier String   @db.VarChar(255)
  token      String   @unique @db.VarChar(255)
  expires    DateTime @db.Timestamptz(6)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialId         String  @unique @map("credential_id") @db.VarChar(255)
  userId               String  @map("user_id") @db.Uuid
  providerAccountId    String  @map("provider_account_id") @db.VarChar(191)
  credentialPublicKey  String  @map("credential_public_key")
  counter              Int
  credentialDeviceType String  @map("credential_device_type") @db.VarChar(64)
  credentialBackedUp   Boolean @map("credential_backed_up")
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialId])
  @@map("authenticators")
}

model Team {
  id                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId            String                     @map("organization_id") @db.Uuid
  parentTeamId              String?                    @map("parent_team_id") @db.Uuid
  managerId                 String?                    @map("manager_id") @db.Uuid
  name                      String                     @db.VarChar(160)
  slug                      String                     @db.VarChar(100)
  departmentCode            String                     @map("department_code") @db.VarChar(64)
  type                      TeamType                   @default(DEPARTMENT)
  description               String?
  path                      String                     @default("/")
  depth                     Int                        @default(0)
  isActive                  Boolean                    @default(true) @map("is_active")
  metadata                  Json                       @default("{}")
  createdAt                 DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  version                   Int                        @default(1)
  activityFeed              ActivityFeed[]
  analyticsDailySnapshots   AnalyticsDailySnapshot[]
  analyticsQuarterSnapshots AnalyticsQuarterSnapshot[]
  goalPlans                 GoalPlan[]
  goals                     Goal[]
  kpiAssignments            KpiAssignment[]            @relation("KpiAssignmentTeam")
  kpiDefinitions            KpiDefinition[]
  teamMemberships           TeamMembership[]
  manager                   User?                      @relation("TeamManager", fields: [managerId], references: [id])
  organization              Organization               @relation(fields: [organizationId], references: [id])
  parentTeam                Team?                      @relation("TeamHierarchy", fields: [parentTeamId], references: [id])
  childTeams                Team[]                     @relation("TeamHierarchy")
  members                   User[]                     @relation("UserTeam")

  @@unique([organizationId, slug], map: "teams_org_slug_key")
  @@unique([organizationId, departmentCode], map: "teams_org_department_code_key")
  @@index([organizationId, parentTeamId, isActive], map: "teams_org_parent_active_idx")
  @@index([organizationId, managerId, isActive], map: "teams_org_manager_active_idx")
  @@index([organizationId, departmentCode, isActive], map: "teams_org_department_code_active_idx")
  @@index([organizationId, type, isActive], map: "teams_org_type_active_idx")
  @@map("teams")
}

model TeamMembership {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  teamId         String             @map("team_id") @db.Uuid
  userId         String             @map("user_id") @db.Uuid
  role           TeamMembershipRole @default(MEMBER)
  startsAt       DateTime           @default(now()) @map("starts_at") @db.Timestamptz(6)
  endsAt         DateTime?          @map("ends_at") @db.Timestamptz(6)
  isPrimary      Boolean            @default(false) @map("is_primary")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization       @relation(fields: [organizationId], references: [id])
  team           Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, teamId, endsAt], map: "team_memberships_org_team_ends_at_idx")
  @@index([organizationId, userId, endsAt], map: "team_memberships_org_user_ends_at_idx")
  @@map("team_memberships")
}

model PerformanceCycle {
  id                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId            String                     @map("organization_id") @db.Uuid
  fiscalYear                Int                        @map("fiscal_year")
  name                      String                     @db.VarChar(160)
  status                    CycleStatus                @default(DRAFT)
  startsAt                  DateTime                   @map("starts_at") @db.Timestamptz(6)
  endsAt                    DateTime                   @map("ends_at") @db.Timestamptz(6)
  metadata                  Json                       @default("{}")
  createdAt                 DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  version                   Int                        @default(1)
  analyticsQuarterSnapshots AnalyticsQuarterSnapshot[]
  goalPlans                 GoalPlan[]
  goals                     Goal[]
  governanceWindows         GovernanceWindow[]
  kpiDefinitions            KpiDefinition[]
  organization              Organization               @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, fiscalYear], map: "performance_cycles_org_fiscal_year_key")
  @@index([organizationId, status], map: "performance_cycles_org_status_idx")
  @@map("performance_cycles")
}

model GovernanceWindow {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  cycleId        String                 @map("cycle_id") @db.Uuid
  type           GovernanceWindowType
  quarter        Quarter                @default(NONE)
  status         GovernanceWindowStatus @default(UPCOMING)
  name           String                 @db.VarChar(160)
  opensAt        DateTime               @map("opens_at") @db.Timestamptz(6)
  closesAt       DateTime               @map("closes_at") @db.Timestamptz(6)
  locksAt        DateTime               @map("locks_at") @db.Timestamptz(6)
  metadata       Json                   @default("{}")
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  version        Int                    @default(1)
  checkIns       CheckIn[]
  escalationLogs EscalationLog[]
  goalApprovals  GoalApproval[]
  cycle          PerformanceCycle       @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  organization   Organization           @relation(fields: [organizationId], references: [id])

  @@unique([cycleId, type, quarter], map: "governance_windows_cycle_type_quarter_key")
  @@index([organizationId, status, opensAt, closesAt], map: "governance_windows_org_status_dates_idx")
  @@index([organizationId, type, quarter], map: "governance_windows_org_type_quarter_idx")
  @@map("governance_windows")
}

model GoalPlan {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  cycleId        String           @map("cycle_id") @db.Uuid
  ownerId        String           @map("owner_id") @db.Uuid
  teamId         String?          @map("team_id") @db.Uuid
  submittedById  String?          @map("submitted_by_id") @db.Uuid
  approvedById   String?          @map("approved_by_id") @db.Uuid
  status         GoalPlanStatus   @default(DRAFT)
  totalWeight    Decimal          @default(0) @map("total_weight") @db.Decimal(5, 2)
  submittedAt    DateTime?        @map("submitted_at") @db.Timestamptz(6)
  approvedAt     DateTime?        @map("approved_at") @db.Timestamptz(6)
  lockedAt       DateTime?        @map("locked_at") @db.Timestamptz(6)
  reworkReason   String?          @map("rework_reason")
  metadata       Json             @default("{}")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  version        Int              @default(1)
  escalationLogs EscalationLog[]
  approvals      GoalApproval[]
  approvedBy     User?            @relation("GoalPlanApprover", fields: [approvedById], references: [id])
  cycle          PerformanceCycle @relation(fields: [cycleId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id])
  owner          User             @relation("GoalPlanOwner", fields: [ownerId], references: [id])
  submittedBy    User?            @relation("GoalPlanSubmitter", fields: [submittedById], references: [id])
  team           Team?            @relation(fields: [teamId], references: [id])
  goals          Goal[]

  @@unique([organizationId, ownerId, cycleId], map: "goal_plans_org_owner_cycle_key")
  @@index([organizationId, status, updatedAt], map: "goal_plans_org_status_updated_at_idx")
  @@index([organizationId, cycleId, status], map: "goal_plans_org_cycle_status_idx")
  @@index([organizationId, teamId, status], map: "goal_plans_org_team_status_idx")
  @@map("goal_plans")
}

model Goal {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String           @map("organization_id") @db.Uuid
  planId               String           @map("plan_id") @db.Uuid
  cycleId              String           @map("cycle_id") @db.Uuid
  ownerId              String           @map("owner_id") @db.Uuid
  teamId               String?          @map("team_id") @db.Uuid
  parentGoalId         String?          @map("parent_goal_id") @db.Uuid
  parentSharedGoalId   String?          @map("parent_shared_goal_id") @db.Uuid
  kpiDefinitionId      String?          @map("kpi_definition_id") @db.Uuid
  approvedById         String?          @map("approved_by_id") @db.Uuid
  createdById          String?          @map("created_by_id") @db.Uuid
  updatedById          String?          @map("updated_by_id") @db.Uuid
  title                String           @db.VarChar(220)
  description          String?
  thrustArea           String?          @map("thrust_area") @db.VarChar(160)
  status               GoalStatus       @default(DRAFT)
  priority             GoalPriority     @default(MEDIUM)
  source               GoalSource       @default(MANUAL)
  visibility           GoalVisibility   @default(TEAM)
  kpiRole              GoalKpiRole      @default(LOCAL) @map("kpi_role")
  uomType              UomType          @default(NUMBER) @map("uom_type")
  scoringMethod        ScoringMethod    @map("scoring_method")
  weightage            Decimal          @db.Decimal(5, 2)
  baselineValue        Decimal?         @map("baseline_value") @db.Decimal(18, 4)
  targetValue          Decimal?         @map("target_value") @db.Decimal(18, 4)
  currentValue         Decimal?         @map("current_value") @db.Decimal(18, 4)
  progressPercent      Decimal          @default(0) @map("progress_percent") @db.Decimal(6, 2)
  score                Decimal?         @db.Decimal(6, 2)
  unit                 String?          @db.VarChar(64)
  startDate            DateTime?        @map("start_date") @db.Timestamptz(6)
  dueDate              DateTime?        @map("due_date") @db.Timestamptz(6)
  lockDate             DateTime?        @map("lock_date") @db.Timestamptz(6)
  isSharedMaster       Boolean          @default(false) @map("is_shared_master")
  isInheritedTarget    Boolean          @default(false) @map("is_inherited_target")
  isTargetEditable     Boolean          @default(true) @map("is_target_editable")
  approvalTimestamp    DateTime?        @map("approval_timestamp") @db.Timestamptz(6)
  kpiDefinitionVersion Int?             @map("kpi_definition_version")
  lastSyncedAt         DateTime?        @map("last_synced_at") @db.Timestamptz(6)
  metadata             Json             @default("{}")
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  version              Int              @default(1)
  activities           ActivityFeed[]
  checkIns             CheckIn[]
  comments             GoalComment[]
  approvedBy           User?            @relation("GoalApprover", fields: [approvedById], references: [id])
  createdBy            User?            @relation("GoalCreator", fields: [createdById], references: [id])
  cycle                PerformanceCycle @relation(fields: [cycleId], references: [id])
  kpiDefinition        KpiDefinition?   @relation(fields: [kpiDefinitionId], references: [id])
  organization         Organization     @relation(fields: [organizationId], references: [id])
  owner                User             @relation("GoalOwner", fields: [ownerId], references: [id])
  parentGoal           Goal?            @relation("GoalHierarchy", fields: [parentGoalId], references: [id])
  childGoals           Goal[]           @relation("GoalHierarchy")
  parentSharedGoal     Goal?            @relation("SharedGoalPropagation", fields: [parentSharedGoalId], references: [id])
  childSharedGoals     Goal[]           @relation("SharedGoalPropagation")
  plan                 GoalPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  team                 Team?            @relation(fields: [teamId], references: [id])
  updatedBy            User?            @relation("GoalUpdater", fields: [updatedById], references: [id])
  sourceSyncLogs       KpiSyncLog[]     @relation("KpiSyncSourceGoal")
  targetSyncLogs       KpiSyncLog[]     @relation("KpiSyncTargetGoal")

  @@index([organizationId, ownerId, cycleId, status], map: "goals_org_owner_cycle_status_idx")
  @@index([organizationId, teamId, cycleId, status], map: "goals_org_team_cycle_status_idx")
  @@index([organizationId, planId, status], map: "goals_org_plan_status_idx")
  @@index([organizationId, priority, dueDate], map: "goals_org_priority_due_date_idx")
  @@index([organizationId, kpiDefinitionId, kpiDefinitionVersion], map: "goals_org_kpi_version_idx")
  @@index([organizationId, isSharedMaster, status], map: "goals_org_shared_master_status_idx")
  @@index([organizationId, parentSharedGoalId], map: "goals_org_parent_shared_goal_idx")
  @@index([organizationId, parentGoalId], map: "goals_org_parent_goal_idx")
  @@index([organizationId, cycleId, status, ownerId, progressPercent], map: "goals_org_cycle_status_owner_progress_idx")
  @@map("goals")
}

model KpiDefinition {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  cycleId        String?           @map("cycle_id") @db.Uuid
  ownerId        String            @map("owner_id") @db.Uuid
  teamId         String?           @map("team_id") @db.Uuid
  parentKpiId    String?           @map("parent_kpi_id") @db.Uuid
  code           String            @db.VarChar(80)
  name           String            @db.VarChar(220)
  description    String?
  status         KpiStatus         @default(DRAFT)
  scoringMethod  ScoringMethod     @map("scoring_method")
  unit           String?           @db.VarChar(64)
  baselineValue  Decimal?          @map("baseline_value") @db.Decimal(18, 4)
  targetValue    Decimal?          @map("target_value") @db.Decimal(18, 4)
  targetDate     DateTime?         @map("target_date") @db.Timestamptz(6)
  currentVersion Int               @default(1) @map("current_version")
  metadata       Json              @default("{}")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  version        Int               @default(1)
  goals          Goal[]
  assignments    KpiAssignment[]
  cycle          PerformanceCycle? @relation(fields: [cycleId], references: [id])
  organization   Organization      @relation(fields: [organizationId], references: [id])
  owner          User              @relation("KpiDefinitionOwner", fields: [ownerId], references: [id])
  parentKpi      KpiDefinition?    @relation("KpiHierarchy", fields: [parentKpiId], references: [id])
  childKpis      KpiDefinition[]   @relation("KpiHierarchy")
  team           Team?             @relation(fields: [teamId], references: [id])
  syncLogs       KpiSyncLog[]

  @@unique([organizationId, code], map: "kpi_definitions_org_code_key")
  @@index([organizationId, ownerId, status], map: "kpi_definitions_org_owner_status_idx")
  @@index([organizationId, teamId, status], map: "kpi_definitions_org_team_status_idx")
  @@index([organizationId, parentKpiId], map: "kpi_definitions_org_parent_kpi_idx")
  @@index([organizationId, cycleId, status], map: "kpi_definitions_org_cycle_status_idx")
  @@map("kpi_definitions")
}

model KpiAssignment {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  kpiDefinitionId  String        @map("kpi_definition_id") @db.Uuid
  assignedToUserId String?       @map("assigned_to_user_id") @db.Uuid
  assignedToTeamId String?       @map("assigned_to_team_id") @db.Uuid
  assignedById     String        @map("assigned_by_id") @db.Uuid
  role             GoalKpiRole   @default(REPLICA)
  localWeight      Decimal?      @map("local_weight") @db.Decimal(5, 2)
  effectiveFrom    DateTime      @default(now()) @map("effective_from") @db.Timestamptz(6)
  effectiveTo      DateTime?     @map("effective_to") @db.Timestamptz(6)
  metadata         Json          @default("{}")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  version          Int           @default(1)
  assignedBy       User          @relation("KpiAssignmentCreator", fields: [assignedById], references: [id])
  assignedToTeam   Team?         @relation("KpiAssignmentTeam", fields: [assignedToTeamId], references: [id], onDelete: Cascade)
  assignedToUser   User?         @relation("KpiAssignmentAssignee", fields: [assignedToUserId], references: [id], onDelete: Cascade)
  kpiDefinition    KpiDefinition @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade)
  organization     Organization  @relation(fields: [organizationId], references: [id])

