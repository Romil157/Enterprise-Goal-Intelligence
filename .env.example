# =============================================================================
# ATOMQUEST | Enterprise Goal Intelligence Platform
# Environment Configuration
# =============================================================================

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atomquest?schema=public"

# --- NextAuth.js v5 ---
AUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_URL="http://localhost:3000"

# --- Microsoft Entra ID (SSO) ---
AZURE_CLIENT_ID="00000000-0000-0000-0000-000000000000"
AZURE_CLIENT_SECRET="replace-with-entra-client-secret"
AZURE_TENANT_ID="00000000-0000-0000-0000-000000000000"
AUTH_ALLOWED_TENANT_IDS="00000000-0000-0000-0000-000000000000"

# --- Entra ID Group-to-Role Mapping ---
ENTRA_ADMIN_GROUP_IDS=""
ENTRA_MANAGER_GROUP_IDS=""
ENTRA_EMPLOYEE_GROUP_IDS=""

# --- Microsoft Graph API (Teams Integration) ---
GRAPH_TENANT_ID="00000000-0000-0000-0000-000000000000"
GRAPH_CLIENT_ID="00000000-0000-0000-0000-000000000000"
GRAPH_CLIENT_SECRET="replace-with-graph-client-secret"

# --- Cron & Background Processing ---
CRON_SECRET="replace-with-a-strong-cron-secret"
